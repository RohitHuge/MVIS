# Copy this file to .env and fill in values for your machine
# cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=daq
POSTGRES_PASSWORD=daq
POSTGRES_DB=daq
POSTGRES_DSN=postgresql://daq:daq@postgres:5432/daq

# ── NATS ───────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Storage ────────────────────────────────────────────────────────────────────
# HOST_CHUNK_DIR : folder on the HOST machine where .bin chunk files land
#   DGX (no sudo) : HOST_CHUNK_DIR=/home/omronix/chunks
#   DGX (with sudo / NVMe at /data) : HOST_CHUNK_DIR=/data/chunks
HOST_CHUNK_DIR=/home/omronix/chunks

# Path inside the containers — keep this as-is
CHUNK_DIR=/data/chunks

# 512 MB per chunk file
CHUNK_MAX_BYTES=536870912

# ── Service ports ──────────────────────────────────────────────────────────────
METRICS_PORT=9100
FETCHER_PORT=8000

# ── Ring buffer ────────────────────────────────────────────────────────────────
RING_CAPACITY=2048
