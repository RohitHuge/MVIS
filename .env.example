# Copy this file to .env and fill in values for your machine
# cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=daq
POSTGRES_PASSWORD=daq
POSTGRES_DB=daq
POSTGRES_DSN=postgresql://daq:daq@postgres:5432/daq

# ── NATS ───────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Storage ────────────────────────────────────────────────────────────────────
# HOST_CHUNK_DIR : folder on the HOST machine where .bin chunk files land
#   DGX (no sudo) : HOST_CHUNK_DIR=/home/omronix/chunks
#   DGX (with sudo / NVMe at /data) : HOST_CHUNK_DIR=/data/chunks
HOST_CHUNK_DIR=/home/omronix/chunks

# Path inside the containers — keep this as-is
CHUNK_DIR=/data/chunks

# 512 MB per chunk file
CHUNK_MAX_BYTES=536870912

# ── Service ports ──────────────────────────────────────────────────────────────
METRICS_PORT=9100
FETCHER_PORT=8000
DASHBOARD_PORT=5000

# ── Ring buffer ────────────────────────────────────────────────────────────────
RING_CAPACITY=2048

# ── Auto-stop guards (prevent filling the drive) ───────────────────────────────
# DEMO_DURATION_S : stop the pipeline automatically after N seconds.
#   0 = run forever (manual Ctrl-C / SIGTERM only).
#   For a 2-minute demo set: DEMO_DURATION_S=120
DEMO_DURATION_S=120

# MIN_FREE_DISK_GB : emergency brake — stop writing when free disk space on
#   CHUNK_DIR falls below this many GB.  Keeps the drive from filling up.
MIN_FREE_DISK_GB=50
